QMainWindow {
    background: #f6f7fb;
}
QToolBar {
    background: #ffffff;
    border-bottom: 1px solid #e1e5ee;
    spacing: 8px;
    padding: 4px;
}
QListWidget, QTabWidget::pane {
    background: #ffffff;
    border: 1px solid #d5dbea;
}
QStatusBar {
    background: #ffffff;
    border-top: 1px solid #e1e5ee;
}
